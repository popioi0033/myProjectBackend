generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Officer {
  id           Int      @id @default(autoincrement())
  officerCode  String   @unique @map("officer_code")
  name         String
  email        String
  institute    String
  jobPosition  String   @map("job_position")
  phone        String
  role         String
  createdAt    DateTime @default(now()) @map("create_at")

  @@map("officers")
}
